#!/usr/bin/env bash

echo "════════════════════════════════════════"
echo "✨ Running system wide updates... "
echo "════════════════════════════════════════"
echo ""

echo "🍺 Updating Homebrew..."
brew update
echo "📋 Checking what's outdated..."
brew outdated
echo "⬆️  Upgrading packages..."
brew upgrade
echo "🖥️  Upgrading casks..."
brew upgrade --cask
echo "🧹 Cleaning up..."
brew cleanup
echo "✅ Homebrew done!"

echo ""
echo "🦀 Updating Rust..."
rustup update
echo "📦 Updating cargo binaries..."
cargo install-update -a
echo "✅ Rust done!"

echo ""
echo "📮 Updating npm globals packages..."
npm update -g
echo "✅ npm done!"

echo ""
echo "📦 Updating pnpm and globals packages..."
pnpm update -g
echo "✅ pnpm done!"

echo ""
echo "📦 Updating Vite+ and global packages..."
vp upgrade
vp update -g
echo "✅ Vite+ done!"

echo ""
echo "📦 Updating Deno..."
deno upgrade
echo "✅ Deno done!"

echo ""
echo "════════════════════════════════════════"
echo "✨ All global dependencies updated! 🎉"
echo "════════════════════════════════════════"
