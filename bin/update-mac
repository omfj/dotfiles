#!/usr/bin/env bash

GREEN='\033[0;32m'
NC='\033[0m'

echo -e "$GREEN[Homebrew]$NC STARTING..."
brew update
brew outdated
brew upgrade
brew upgrade --cask
brew cleanup
echo -e "$GREEN[Homebrew]$NC DONE"

echo -e "$GREEN[Rust]$NC STARTING..."
rustup update
cargo install-update -a
echo -e "$GREEN[Rust]$NC DONE\n"

echo -e "$GREEN[npm]$NC STARTING..."
npm update -g
echo -e "$GREEN[npm]$NC DONE"

echo -e "$GREEN[pnpm]$NC STARTING..."
pnpm update -g
echo -e "$GREEN[pnpm]$NC DONE"

echo -e "$GREEN[vp]$NC STARTING..."
vp upgrade
vp update -g
echo -e "$GREEN[vp]$NC DONE"

echo -e "$GREEN[deno]$NC STARTING..."
deno upgrade
echo -e "$GREEN[deno]$NC DONE"

echo "Done..."
