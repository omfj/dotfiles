# reload config with
# cmd + shift + ,
# or
# ctrl + shift + ,

theme = Jellybeans
background = #0a0a0a

font-family = IosevkaTerm Nerd Font
font-size = 14

shell-integration = fish

window-padding-x = 20
window-padding-y = 20

cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor

link-url = true

copy-on-select = true
window-save-state = always

confirm-close-surface = false

# macos stuff
macos-titlebar-style = tabs

# claude code?
keybind = shift+enter=text:\x1b\r

# pane management
keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:bottom
keybind = alt+k=goto_split:top
keybind = alt+l=goto_split:right

# create new splits
keybind = ctrl+a>-=new_split:down
keybind = ctrl+a>alt+8=new_split:right

# destory splits
# ctrl+w or ctrl+shift+w depending on mac or linux

# resize splits
keybind = ctrl+shift+j=resize_split:up,10
keybind = ctrl+shift+k=resize_split:down,10
keybind = ctrl+shift+h=resize_split:left,10
keybind = ctrl+shift+l=resize_split:right,10
keybind = ctrl+shift+e=equalize_splits

# fullscreen (monocle) split
keybind = ctrl+a>f=toggle_split_zoom

# rename tabs
keybind = ctrl+a>r=prompt_surface_title

# scrolling configuration
mouse-scroll-multiplier = 3
scrollback-limit = 500000000

# option key word navigation and deletion
keybind = opt+left=text:\x1b[1;5D
keybind = opt+right=text:\x1b[1;5C
keybind = opt+backspace=text:\x17
