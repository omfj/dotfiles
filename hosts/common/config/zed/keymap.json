// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": [
        "workspace::SendKeystrokes",
        "escape"
      ],
      "cmd-i": "editor::ShowCompletions"
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      // Remove jk and jj to escape insert mode.
      "j k": null,
      "j j": null,
      // Use j and k to navigate soft wrapped lines.
      "j": [
        "workspace::SendKeystrokes",
        "g j"
      ],
      "k": [
        "workspace::SendKeystrokes",
        "g k"
      ],
      // Use H and L to navigate between panes.
      "L": "pane::ActivateNextItem",
      "H": "pane::ActivatePreviousItem",
    }
  },
  // Add Helix Amp Jump / Sneak. Not yet in stable.
  {
    "context": "VimControl && !menu",
    "bindings": {
      "s": "vim::HelixJumpToWord",
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // Remove jk and jj to escape insert mode.
      "j k": null,
      "j j": null
    }
  }
]
