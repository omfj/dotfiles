# Functions

function has() {
    command -v "$1" &>/dev/null
}

# Environment variables

export EDITOR=nvim
export GOPATH=$HOME/go
export XDG_CONFIG_HOME=$HOME/.config
export PROGRAMMING=$HOME/Developer
export DOTFILES=$PROGRAMMING/github/dotfiles

# Set to Emacs keybindings, since Zsh automatically uses Vi keybinds
# if it detects "vi" in $EDITOR or $VISUAL, which is the case for Neovim.
bindkey -e

# PATH

typeset -U path

path=(
    $HOME/.vite-plus/bin
    $HOME/.cargo/bin
    $HOME/.local/bin
    $HOME/.atuin/bin
    $HOME/.opencode/bin

    /usr/local/bin
    /usr/local/sbin
    /usr/local/opt/openjdk/bin

    $path
)

export PATH

# Aliases

alias l="eza"
alias ls="eza"
alias la="eza -a"
alias ll="eza -l"
alias lla="eza -la"

alias g="git"
alias ga="git add"
alias gc="git commit -m"

alias b="brew"
alias bi="brew install"
alias bu="$DOTFILES/bin/update-mac"

alias lg="lazygit"

alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ......="cd ../../../../.."
alias .........="cd ../../../../../.."
alias ..........="cd ../../../../../../.."

alias dots="cd $DOTFILES"
alias conf="cd $HOME/.config"

# Functions

function uuid() {
    local id=$(uuidgen | tr '[:upper:]' '[:lower:]')
    if has pbcopy; then
        print -rn -- "$id" | pbcopy
    elif has wl-copy; then
        print -rn -- "$id" | wl-copy
    elif has xclip; then
        print -rn -- "$id" | xclip -selection clipboard
    fi
    echo "$id"
}

function claude() {
    env SHELL=/usr/bin/bash claude "$@"
}

# bat

if has batcat; then
    alias bat="batcat"
    alias cat="bat"
elif has bat; then
    alias cat="bat"
fi

# Zoxide

if has zoxide; then
    eval "$(zoxide init --cmd cd zsh)"
fi

# Atuin

if has atuin; then
    eval "$(atuin init zsh --disable-up-arrow)"
fi

# Vite+

if [[ -f "$HOME/.vite-plus/env" ]]; then
    source "$HOME/.vite-plus/env"
fi

# Zinit

ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -r "$ZINIT_HOME/zinit.zsh" ]] && command -v git >/dev/null; then
    mkdir -p "${ZINIT_HOME:h}"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

if [[ -r "$ZINIT_HOME/zinit.zsh" ]]; then
    source "$ZINIT_HOME/zinit.zsh"
    zinit light zsh-users/zsh-autosuggestions
fi

# Starship

if has starship; then
    eval "$(starship init zsh)"
fi

# zsh-patina (must be last, since it needs to own the zle widgets)

if (( $+functions[zinit] )); then
    zinit ice as"program" from"gh-r" pick"zsh-patina-*/zsh-patina" atload'eval "$(zsh-patina activate)"'
    zinit light michel-kraemer/zsh-patina
fi
